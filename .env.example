# Database
DATABASE_URL=local.db

# Admin account (one hardcoded admin)
# Generate hash: node -e "import('bcrypt').then(b => b.default.hash('yourpassword', 10).then(console.log))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

