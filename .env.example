# Database
DATABASE_URL=local.db

# Admin password is NOT stored here — run: npm run set-password
# (bcrypt hashes contain `$`, which .env parsing silently corrupts)

# Production only: the public URL Caddy serves the site on.
# adapter-node needs it or every form post 403s (CSRF check).
# ORIGIN=https://beta.mermaidmonnieofficial.com

# Production image storage (not needed for local dev)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-2
# AWS_S3_BUCKET=monniemermaid
# CDN_URL=cdn.mermaidmonnieofficial.com
